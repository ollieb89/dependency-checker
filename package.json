{
  "name": "dependency-checker",
  "version": "1.0.0",
  "description": "GitHub Action to scan and report outdated and vulnerable dependencies",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.js -o dist --minify",
    "test": "node src/index.js",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "npm-check-updates": "^16.14.20"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.1"
  },
  "keywords": [
    "github-action",
    "npm",
    "security",
    "dependencies",
    "vulnerable",
    "outdated"
  ]
}
